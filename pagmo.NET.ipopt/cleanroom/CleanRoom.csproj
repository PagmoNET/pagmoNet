<Project Sdk="Microsoft.NET.Sdk">

  <!--
    Throwaway consumer used by the publish workflow's clean-room gate. It references
    the *published-shaped* Pagmo.NET.Ipopt .nupkg from a local feed (see the workflow,
    which writes a nuget.config and runs `dotnet add package`), then runs one IPOPT
    solve. The PackageReference is added at job time so the version always matches the
    artifact under test.
  -->

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>disable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <Platforms>x64</Platforms>
    <!-- The workflow writes a nuget.config next to this project with <clear/> + ONE local feed
         holding BOTH the companion under test and the same-version base Pagmo.NET (built in the
         same run). Restore is fully offline, so the gate proves base + companion without any
         publish. -->
  </PropertyGroup>

</Project>
