<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <!-- References the PUBLISHED companion package from NuGet.org. It pulls in the base Pagmo.NET
         automatically AND supplies the native IPOPT runtime, so `dotnet run` restores everything
         (managed + native) with no build toolchain, vcpkg, or cmake.

         To see the graceful "IPOPT not available" path instead, swap this for the base package:
             <PackageReference Include="Pagmo.NET" Version="*-*" />
         The "ipopt" scenario then prints a friendly note and skips; every other scenario still runs.

         Version "*-*" floats to the newest published release (incl. prereleases), so it never needs
         bumping. Pin it to an explicit version like "1.0.0" for a reproducible build. -->
    <PackageReference Include="Pagmo.NET.Ipopt" Version="*-*" />
  </ItemGroup>

</Project>
